{
  "name": "community-priorities-maps",
  "version": "1.0.0",
  "private": true,
  "description": "Community Priorities and Cluster Priorities Leaflet maps",
  "scripts": {
    "dev": "serve dist -l 5173",
    "preview": "serve dist -l 5173",
    "sync:priorities": "powershell -NoProfile -ExecutionPolicy Bypass -File ../sync-community-priorities-map.ps1",
    "sync:cluster-priorities": "powershell -NoProfile -ExecutionPolicy Bypass -File ../sync-cluster-priorities-map.ps1",
    "generate:cluster-priorities": "npm --prefix ../deployed run generate:infrastructure",
    "generate:community-priorities": "npm --prefix ../deployed run generate:data",
    "sync:all-priorities": "npm run sync:priorities && npm run sync:cluster-priorities",
    "sync:images": "powershell -NoProfile -ExecutionPolicy Bypass -File ../sync-priority-map-images-to-s3.ps1",
    "deploy:maps": "powershell -NoProfile -ExecutionPolicy Bypass -File ../deploy-maps-to-aws.ps1",
    "deploy:maps:isolated": "powershell -NoProfile -ExecutionPolicy Bypass -File ../deploy-community-priorities-map-isolated-to-aws.ps1",
    "deploy:priorities:isolated": "powershell -NoProfile -ExecutionPolicy Bypass -File ../deploy-community-priorities-map-isolated-to-aws.ps1",
    "test:online": "powershell -NoProfile -ExecutionPolicy Bypass -File ../test-deployment-online.ps1",
    "regenerate:priorities-source": "node ../scripts/extract-community-priorities-source.mjs"
  },
  "devDependencies": {
    "serve": "^14.2.4"
  }
}
